# =============================================================================
# Stock Tracker — Environment Variables (Lightsail Deployment)
# =============================================================================
# Copy to .env in the project root: cp deploy/.env.example .env
# Then fill in your credentials below.

# --- Angel One SmartAPI Credentials ---
# Get these from https://smartapi.angelone.in
# Leave empty to fall back to yfinance (delayed 15-20 min data)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# --- Authentication ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS Origins ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://YOUR_LIGHTSAIL_IP

# --- Resource Mode ---
# Set to true on memory-constrained servers (1 GB RAM) to limit TF/torch threads
LOW_RESOURCE_MODE=true

# --- Finnhub (optional) ---
# For additional news/market data
FINNHUB_API_KEY=
